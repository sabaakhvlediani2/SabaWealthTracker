<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/sa_ni_background">

    <TextView
        android:id="@+id/sa_ni_tv_analytics_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Results"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/sa_ni_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp"
        android:layout_marginStart="8dp" />

    <TextView
        android:id="@+id/sa_ni_tv_placeholder"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Nothing here yet. Add your data first."
        android:textSize="14sp"
        android:textColor="@color/sa_ni_text_secondary"
        app:layout_constraintTop_toBottomOf="@id/sa_ni_tv_analytics_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/sa_ni_tv_income"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Your Income: -"
        android:textSize="16sp"
        android:textColor="@color/sa_ni_text_primary"
        android:visibility="gone"
        android:layout_marginTop="36dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/sa_ni_tv_analytics_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/sa_ni_tv_expenses"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Your Expenses: -"
        android:textSize="16sp"
        android:textColor="@color/sa_ni_text_primary"
        android:visibility="gone"
        android:layout_marginTop="14dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/sa_ni_tv_income"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/sa_ni_tv_net"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Net: -"
        android:textSize="16sp"
        android:textColor="@color/sa_ni_text_primary"
        android:visibility="gone"
        android:layout_marginTop="14dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/sa_ni_tv_expenses"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/sa_ni_tv_k_value"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Coefficient (K): -"
        android:textSize="16sp"
        android:textColor="@color/sa_ni_text_secondary"
        android:visibility="gone"
        android:layout_marginTop="14dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/sa_ni_tv_net"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/sa_ni_tv_savings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Total Savings: -"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/sa_ni_savings_green"
        android:visibility="gone"
        android:layout_marginTop="28dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/sa_ni_tv_k_value"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
