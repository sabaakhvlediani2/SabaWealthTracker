<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/sa_ni_background">

    <TextView
        android:id="@+id/sa_ni_tv_profile_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="About Me"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/sa_ni_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp"
        android:layout_marginStart="8dp" />

    <TextView
        android:id="@+id/sa_ni_tv_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Student: \u10E1\u10D0\u10D1\u10D0 \u10D0\u10EE\u10D5\u10DA\u10D4\u10D3\u10D8\u10D0\u10DC\u10D8"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/sa_ni_text_primary"
        android:layout_marginTop="36dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/sa_ni_tv_profile_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/sa_ni_tv_formula"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Formula: K = (4 + 10) / 22 = 0.6364"
        android:textSize="15sp"
        android:textColor="@color/sa_ni_text_primary"
        android:layout_marginTop="20dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/sa_ni_tv_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/sa_ni_tv_orientation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Scroll Direction: Horizontal (\u10D0 is a vowel)"
        android:textSize="15sp"
        android:textColor="@color/sa_ni_text_primary"
        android:layout_marginTop="20dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/sa_ni_tv_formula"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/sa_ni_tv_prefix"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Resource Prefix: sa_ni_"
        android:textSize="15sp"
        android:textColor="@color/sa_ni_text_primary"
        android:layout_marginTop="20dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/sa_ni_tv_orientation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
